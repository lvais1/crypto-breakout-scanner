TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DATABASE_PATH=scanner.db
LOG_LEVEL=INFO
DEBUG_DECISIONS=true
SYMBOLS=["BTCUSDT","ETHUSDT"]
TIMEFRAME=5m
PAPER_MONITORING_ENABLED=true
TP1_CLOSE_FRACTION=0.40
TP2_CLOSE_FRACTION=0.40
TP3_CLOSE_FRACTION=0.20
MOVE_STOP_TO_BREAK_EVEN_AFTER_TP1=true
STOP_AFTER_TP2=TP1
MARK_PRICE_STALE_SECONDS=30
PAPER_STATUS_UPDATES_ENABLED=false
# Live order execution does not exist in this project by design.
